# outlook-cli agent — example environment file.
# Copy to .env (which is git-ignored) and fill in only the vars for the
# provider you use. Process environment variables override .env. Do NOT
# commit .env.
#
# ALTERNATIVE: set secrets in ~/.tool-agents/outlook-cli/.env (seeded on
# first run with placeholder values). Process env > cwd/.env >
# ~/.tool-agents/outlook-cli/.env > ~/.tool-agents/outlook-cli/config.json.
#
# Precedence (v2.0.0+, per standard_conventions):
#   CLI flag > process env > cwd/.env > ~/.tool-agents/outlook-cli/.env
#   > ~/.tool-agents/outlook-cli/config.json > default (optional) / throw.
#
# Mandatory rows have NO default — missing them raises a ConfigurationError
# (exit 3).

# ── Global agent controls (OUTLOOK_AGENT_* prefix — keep prefixed) ────────
# Selects the LLM provider factory. One of:
#   openai | anthropic | gemini | azure-openai | azure-anthropic |
#   local-openai | azure-deepseek (project extension, not canonical)
# Mandatory (no default).
# Note: 'google' is accepted as a deprecated alias for 'gemini'.
# OUTLOOK_AGENT_PROVIDER=openai

# Model id / deployment name. Required for openai, anthropic, gemini,
# azure-deepseek, azure-anthropic (also accepted via --model). For
# azure-openai the deployment is set via AZURE_OPENAI_DEPLOYMENT.
# OUTLOOK_AGENT_MODEL=gpt-4o-mini

# ReAct iteration ceiling (1..50). Default: 10.
# OUTLOOK_AGENT_MAX_STEPS=10

# Sampling temperature. Default: 0.
# OUTLOOK_AGENT_TEMPERATURE=0

# Inline system prompt override. Mutually exclusive with
# OUTLOOK_AGENT_SYSTEM_PROMPT_FILE.
# OUTLOOK_AGENT_SYSTEM_PROMPT=

# File-backed system prompt. Path to a UTF-8 text file. Mutually exclusive
# with OUTLOOK_AGENT_SYSTEM_PROMPT.
# OUTLOOK_AGENT_SYSTEM_PROMPT_FILE=

# CSV allowlist of tool names to register. Default: full permitted set.
# OUTLOOK_AGENT_TOOLS=

# Per-tool result byte budget for truncation. Default: 16384.
# OUTLOOK_AGENT_PER_TOOL_BUDGET_BYTES=16384

# Enables mutating tools (create_folder, move_mail, download_attachments).
# Default: false.
# OUTLOOK_AGENT_ALLOW_MUTATIONS=false

# ── OpenAI (standard vendor names — v2.0.0+) ─────────────────────────────
# Required for provider=openai.
# OPENAI_API_KEY=

# Optional gateway override (e.g. self-hosted proxy). Also used by
# local-openai as the primary base URL.
# OPENAI_BASE_URL=

# Optional OpenAI organization id.
# OPENAI_ORG_ID=

# ── Anthropic (standard vendor names) ─────────────────────────────────────
# Required for provider=anthropic.
# ANTHROPIC_API_KEY=

# Optional gateway override.
# ANTHROPIC_BASE_URL=

# ── Google Gemini (standard vendor names) ─────────────────────────────────
# Required for provider=gemini (or deprecated alias 'google').
# GOOGLE_API_KEY=
# GEMINI_API_KEY=     # alias for GOOGLE_API_KEY; either is accepted

# ── Azure OpenAI (standard vendor names) ──────────────────────────────────
# All four are required for provider=azure-openai.
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
# AZURE_OPENAI_API_VERSION=2024-10-21
# AZURE_OPENAI_DEPLOYMENT=

# ── local-openai ──────────────────────────────────────────────────────────
# At least one of these is required for provider=local-openai.
# OPENAI_BASE_URL is checked first, then LOCAL_OPENAI_BASE_URL, then
# OLLAMA_HOST (mapped to http://<host>/v1).
# OPENAI_API_KEY is optional — defaults to "not-needed" when absent.
# OPENAI_BASE_URL=http://localhost:11434/v1
# LOCAL_OPENAI_BASE_URL=http://localhost:11434/v1
# OLLAMA_HOST=localhost:11434

# ── Azure AI Foundry (shared by azure-anthropic and azure-deepseek) ───────
# Foundry resource key. Required when provider is azure-anthropic or
# azure-deepseek.
# AZURE_AI_INFERENCE_KEY=

# Foundry resource base URL. The factory strips trailing "/" and "/models",
# then appends "/anthropic" (azure-anthropic) or "/openai/v1"
# (azure-deepseek). Required when provider is azure-anthropic or
# azure-deepseek.
# AZURE_AI_INFERENCE_ENDPOINT=https://<resource>.services.ai.azure.com

# ── Azure-hosted Anthropic (Microsoft Foundry) ────────────────────────────
# Foundry deployment name for the Anthropic model. May also be supplied
# via --model or OUTLOOK_AGENT_MODEL.
# AZURE_ANTHROPIC_MODEL=claude-sonnet-4-5

# ── Azure-hosted DeepSeek (Microsoft Foundry /openai/v1) ──────────────────
# Project-extension provider (not in the canonical 6-slot standard set).
# Foundry deployment name. May also be supplied via --model or
# OUTLOOK_AGENT_MODEL. Rejected at config load if it matches the denylist
# in project-design §5.6.
# AZURE_DEEPSEEK_MODEL=DeepSeek-V3.2

# --- Agent TUI (plan-004) -------------------------------------------------
# Interactive-mode persistence. Defaults are usually fine.
# OUTLOOK_AGENT_MEMORY_FILE=
# OUTLOOK_AGENT_MODEL_FILE=
# Defaults (used when unset):
#   memory: $HOME/.outlook-cli/agent-memory.json
#   model:  $HOME/.outlook-cli/agent-model.json
# Both files are mode 0600 inside a 0700 parent dir.
