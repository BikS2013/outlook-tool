# outlook-cli — example environment file.
# Copy to .env (which is git-ignored) and fill in only the vars you need.
# Process environment variables override .env. Do NOT commit .env.
#
# Precedence (per project conventions):
#   CLI flag > process env > cwd/.env > default (where allowed) / throw.
#
# Most settings have safe defaults; only override when needed.

# ── Runtime plumbing (project-specific defaults allowed) ──────────────────
# Per-REST-call HTTP timeout in ms. Default: 30000 (30 s).
# OUTLOOK_CLI_HTTP_TIMEOUT_MS=30000

# Interactive-login timeout in ms. Default: 300000 (5 min).
# OUTLOOK_CLI_LOGIN_TIMEOUT_MS=300000

# Playwright Chrome channel. Default: chrome.
# OUTLOOK_CLI_CHROME_CHANNEL=chrome

# ── Optional file-system overrides ────────────────────────────────────────
# Path to the persisted session JSON.
# Default: $HOME/.tool-agents/outlook-cli/session.json
# OUTLOOK_CLI_SESSION_FILE=

# Path to the Playwright user-data dir.
# Default: $HOME/.tool-agents/outlook-cli/playwright-profile
# OUTLOOK_CLI_PROFILE_DIR=

# ── Optional locale/timezone overrides ────────────────────────────────────
# IANA timezone. Default: process.env.TZ ?? Intl system tz.
# OUTLOOK_CLI_TZ=Europe/Athens

# Calendar default range (used by `list-calendar` when --from/--to omitted).
# OUTLOOK_CLI_CAL_FROM=
# OUTLOOK_CLI_CAL_TO=
