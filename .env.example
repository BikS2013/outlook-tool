# outlook-cli agent — example environment file.
# Copy to .env (which is git-ignored) and fill in only the vars for the
# provider you use. Process environment variables override .env. Do NOT
# commit .env.
#
# Precedence (per project-design §4): CLI flag > process env > .env file >
# default (optional rows only). Mandatory rows have NO default — missing
# them raises a ConfigurationError (exit 3).

# ── Global agent controls ─────────────────────────────────────────────────
# Selects the LLM provider factory. One of:
#   openai | anthropic | google | azure-openai | azure-anthropic | azure-deepseek
# Mandatory (no default).
# OUTLOOK_AGENT_PROVIDER=openai

# Model id / deployment name. Required for openai, anthropic, google,
# azure-deepseek, azure-anthropic (also accepted via --model). For
# azure-openai the deployment is set via OUTLOOK_AGENT_AZURE_OPENAI_DEPLOYMENT.
# OUTLOOK_AGENT_MODEL=gpt-4o-mini

# ReAct iteration ceiling (1..50). Default: 10.
# OUTLOOK_AGENT_MAX_STEPS=10

# Sampling temperature. Default: 0.
# OUTLOOK_AGENT_TEMPERATURE=0

# Inline system prompt override. Overrides the built-in default (see
# project-design §11). Mutually exclusive with OUTLOOK_AGENT_SYSTEM_PROMPT_FILE.
# OUTLOOK_AGENT_SYSTEM_PROMPT=

# File-backed system prompt. Path to a UTF-8 text file. Mutually exclusive
# with OUTLOOK_AGENT_SYSTEM_PROMPT.
# OUTLOOK_AGENT_SYSTEM_PROMPT_FILE=

# CSV allowlist of tool names to register. Default: full permitted set (all
# 11 tools when --allow-mutations, 8 read-only tools otherwise).
# OUTLOOK_AGENT_TOOLS=

# Per-tool result byte budget for truncation. Default: 16384.
# OUTLOOK_AGENT_TOOL_OUTPUT_BUDGET_BYTES=16384

# Enables mutating tools (create_folder, move_mail, download_attachments).
# Default: false.
# OUTLOOK_AGENT_ALLOW_MUTATIONS=false

# ── OpenAI ────────────────────────────────────────────────────────────────
# Required for provider=openai.
# OUTLOOK_AGENT_OPENAI_API_KEY=

# Optional gateway override (e.g. self-hosted proxy).
# OUTLOOK_AGENT_OPENAI_BASE_URL=

# Optional OpenAI organization id.
# OUTLOOK_AGENT_OPENAI_ORG=

# ── Anthropic (native) ────────────────────────────────────────────────────
# Required for provider=anthropic.
# OUTLOOK_AGENT_ANTHROPIC_API_KEY=

# Optional gateway override.
# OUTLOOK_AGENT_ANTHROPIC_BASE_URL=

# ── Google Gemini ─────────────────────────────────────────────────────────
# Required for provider=google.
# OUTLOOK_AGENT_GOOGLE_API_KEY=

# ── Azure OpenAI ──────────────────────────────────────────────────────────
# All four are required for provider=azure-openai.
# OUTLOOK_AGENT_AZURE_OPENAI_API_KEY=
# OUTLOOK_AGENT_AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
# OUTLOOK_AGENT_AZURE_OPENAI_API_VERSION=2024-10-21
# OUTLOOK_AGENT_AZURE_OPENAI_DEPLOYMENT=

# ── Azure AI Foundry (shared by azure-anthropic and azure-deepseek) ───────
# Foundry resource key. Required when provider is azure-anthropic or
# azure-deepseek.
# OUTLOOK_AGENT_AZURE_AI_INFERENCE_KEY=

# Foundry resource base URL. The factory strips trailing "/" and "/models",
# then appends "/anthropic" (azure-anthropic) or "/openai/v1"
# (azure-deepseek). Required when provider is azure-anthropic or
# azure-deepseek.
# OUTLOOK_AGENT_AZURE_AI_INFERENCE_ENDPOINT=https://<resource>.services.ai.azure.com

# Informational only — retained for audit. NOT passed to any constructor
# (ChatAnthropic manages anthropic-version itself; the OpenAI-compatible
# Foundry endpoint does not require an api-version query param in v1).
# OUTLOOK_AGENT_AZURE_AI_INFERENCE_API_VERSION=

# ── Azure-hosted Anthropic (Microsoft Foundry) ────────────────────────────
# Foundry deployment name for the Anthropic model (e.g. claude-sonnet-4-5,
# claude-opus-4-7, claude-haiku-4-5). May also be supplied via --model.
# OUTLOOK_AGENT_AZURE_ANTHROPIC_MODEL=claude-sonnet-4-5

# ── Azure-hosted DeepSeek (Microsoft Foundry /openai/v1) ──────────────────
# Foundry deployment name (e.g. DeepSeek-V3.2, DeepSeek-V3.1). May also be
# supplied via --model. Rejected at config load if it matches the denylist
# in project-design §5.6 (DeepSeek-R1, DeepSeek-V3.2-Speciale — no
# tool-calling support).
# OUTLOOK_AGENT_AZURE_DEEPSEEK_MODEL=DeepSeek-V3.2

# --- Agent TUI (plan-004) -------------------------------------------------
# Interactive-mode persistence. Defaults are usually fine.
OUTLOOK_AGENT_MEMORY_FILE=
OUTLOOK_AGENT_MODEL_FILE=
# Defaults (used when unset):
#   memory: $HOME/.outlook-cli/agent-memory.json
#   model:  $HOME/.outlook-cli/agent-model.json
# Both files are mode 0600 inside a 0700 parent dir.
